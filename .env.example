# Story2Video 环境变量配置
# 复制此文件为 .env 并填入实际值

# Supabase（必需）
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# 编排器 API（可选）
VITE_ORCHESTRATOR_URL=/api

# 智能分句服务 smart-sentence-splitter（可选，留空则使用本地 TS 实现）
VITE_SENTENCE_SPLITTER_URL=http://localhost:8014

# 提示词引擎 prompt-engine（可选，留空则使用本地 TS 实现）
VITE_PROMPT_ENGINE_URL=http://localhost:8013
