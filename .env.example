# Story2Video 环境变量配置
# 复制此文件为 .env 并填写实际值

# Supabase（必需）
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase 代理模式（可选，默认 true）
# 设为 false 可禁用 customFetch 中的代理路径重写逻辑
# VITE_SUPABASE_PROXY=true

# 编排器 API（可选）
VITE_ORCHESTRATOR_URL=/api

# 智能分句服务 smart-sentence-splitter（可选，留空则使用本地 TS 实现）
VITE_SENTENCE_SPLITTER_URL=http://localhost:8000

# 提示词引擎 prompt-engine（可选，留空则使用本地 TS 实现）
VITE_PROMPT_ENGINE_URL=http://localhost:8013